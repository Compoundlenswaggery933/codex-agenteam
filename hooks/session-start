#!/usr/bin/env bash
# AgenTeam SessionStart hook — read-only startup signaler.
# Outputs JSON with additional_context for session injection.
# No state mutation, no config resolution, no auto-resume.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
RUNTIME="$PLUGIN_ROOT/runtime/agenteam_rt.py"

# --- Build context text ---
context="AgenTeam plugin is available.\nCore commands: run, assign, status, resume"

# --- HOTL detection ---
hotl_json=$(python3 "$RUNTIME" hotl check 2>/dev/null || echo '{"available":false}')
hotl_available=$(echo "$hotl_json" | python3 -c "import sys,json; print(json.load(sys.stdin).get('available',False))" 2>/dev/null || echo "False")

if [ "$hotl_available" = "True" ]; then
    context="$context\n\nHOTL plugin: available (skills: tdd, code-review, systematic-debugging)"
else
    context="$context\n\nHOTL plugin: not installed"
fi

# --- Interrupted run detection ---
resume_json=$(python3 "$RUNTIME" resume-detect 2>/dev/null || echo '{"resumable_runs":[]}')
resume_info=$(echo "$resume_json" | python3 -c "
import sys, json
data = json.load(sys.stdin)
runs = data.get('resumable_runs', [])
if runs:
    r = runs[0]
    print(f'Interrupted run detected: \"{r[\"task\"]}\" at stage {r[\"stage\"]}.\nResume with: @ATeam resume {r[\"run_id\"]}')
" 2>/dev/null || true)

if [ -n "$resume_info" ]; then
    context="$context\n\n$resume_info"
fi

# --- Output JSON contract ---
# Use python to safely JSON-encode the context string
python3 -c "
import json, sys
context = '''$(echo -e "$context")'''
output = {
    'additional_context': context,
    'hookSpecificOutput': {
        'hookEventName': 'SessionStart',
        'additionalContext': context
    }
}
json.dump(output, sys.stdout)
"
