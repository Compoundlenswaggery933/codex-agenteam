version: "1"

# --- Branch isolation for writing agents ---
# isolation: branch           # branch (default) | worktree | none

# --- Force HOTL execution (auto-detected when omitted) ---
# pipeline: hotl

# --- Role overrides (deep-merged with built-in defaults) ---
roles:
  dev:
    model: gpt-5.3-codex
    can_write: true
    write_scope:
      - "src/**"
      - "lib/**"
      - "docs/plans/**"

  qa:
    model: gpt-5.3-codex
    can_write: true
    write_scope:
      - "tests/**"
      - "**/*.test.*"

  # Custom role example — uncomment and modify
  # security_auditor:
  #   description: "Reviews code for security vulnerabilities"
  #   participates_in: [review]
  #   can_write: false
  #   system_instructions: |
  #     Focus on OWASP top 10, auth/authz logic, and hardcoded secrets.

# --- Pipeline stages (omit for ad-hoc dispatch only) ---
pipeline:
  stages:
    - name: research
      roles: [researcher]
      gate: auto

    - name: strategy
      roles: [pm]
      gate: human

    - name: design
      roles: [architect, pm, researcher]
      gate: human

    - name: plan
      roles: [dev]
      gate: human

    - name: implement
      roles: [dev]
      gate: auto

    - name: test
      roles: [qa]
      gate: auto

    - name: review
      roles: [reviewer]
      gate: human
